{
  "name": "powerchart",
  "version": "0.1.0",
  "description": "Open-source think-cell-style chart add-in for PowerPoint (Office.js). Waterfall, Mekko, stacked/clustered columns, CAGR & difference arrows \u2014 rendered as native, editable PowerPoint shapes.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "render": "node scripts/render-batch.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "icons": "node scripts/make-icons.mjs",
    "gallery": "node scripts/render-gallery.mjs",
    "skill": "npm run build:lib && node scripts/build-skill.mjs",
    "showcase": "npm run build:lib && node scripts/build-showcase.mjs"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "playwright-core": "^1.61.1",
    "pptxgenjs": "^4.0.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
