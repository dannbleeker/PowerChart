{
  "name": "powerchart",
  "version": "0.1.0",
  "description": "Open-source think-cell-style chart add-in for PowerPoint (Office.js). Waterfall, Mekko, stacked/clustered columns, CAGR & difference arrows — rendered as native, editable PowerPoint shapes.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:manifest": "node scripts/build-manifest.mjs",
    "build:pages": "npm run build:manifest && tsc --noEmit && vite build && node scripts/pages-postbuild.mjs",
    "render": "node scripts/render-batch.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "icons": "node scripts/make-icons.mjs",
    "gallery": "node scripts/render-gallery.mjs",
    "skill": "npm run build:lib && node scripts/build-skill.mjs",
    "showcase": "npm run build:lib && node scripts/build-showcase.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "@types/office-js": "^1.0.377",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1",
    "pptxgenjs": "^4.0.1",
    "prettier": "^3.9.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
